[gd_scene load_steps=3 format=3]

[node name="MainMenu" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Panel" type="Panel" parent="."]
anchor_left = 0.25
anchor_top = 0.2
anchor_right = 0.75
anchor_bottom = 0.8
margin_left = 0.0
margin_top = 0.0
margin_right = 0.0
margin_bottom = 0.0
theme = ExtResource( 1 )

[node name="VBox" type="VBoxContainer" parent="Panel"]
anchor_left = 0.1
anchor_top = 0.1
anchor_right = 0.9
anchor_bottom = 0.9
margin_left = 0.0
margin_top = 0.0
margin_right = 0.0
margin_bottom = 0.0

[node name="Title" type="Label" parent="Panel/VBox"]
text = "HEYLA Kids: Guardians of Tomorrow"
align = 1
valign = 0
custom_fonts/font = ExtResource( 2 )

[node name="Play" type="Button" parent="Panel/VBox"]
text = "Play"
connect("pressed", NodePath(".."), "_on_play_pressed")

[node name="Continue" type="Button" parent="Panel/VBox"]
text = "Continue"
connect("pressed", NodePath(".."), "_on_continue_pressed")

[node name="Options" type="Button" parent="Panel/VBox"]
text = "Options"
connect("pressed", NodePath(".."), "_on_options_pressed")

[node name="Credits" type="Button" parent="Panel/VBox"]
text = "Credits"
connect("pressed", NodePath(".."), "_on_credits_pressed")

[node name="Quit" type="Button" parent="Panel/VBox"]
text = "Quit"
connect("pressed", NodePath(".."), "_on_quit_pressed")

[ext_resource path="res://Project/assets/ui/theme.tres" type="Theme" id=1]
[ext_resource path="res://Project/assets/fonts/Nunito-Regular.ttf" type="DynamicFontData" id=2]
[connection signal="pressed" from="Panel/VBox/Play" to="Panel" method="_on_play_pressed"]
[connection signal="pressed" from="Panel/VBox/Continue" to="Panel" method="_on_continue_pressed"]
[connection signal="pressed" from="Panel/VBox/Options" to="Panel" method="_on_options_pressed"]
[connection signal="pressed" from="Panel/VBox/Credits" to="Panel" method="_on_credits_pressed"]
[connection signal="pressed" from="Panel/VBox/Quit" to="Panel" method="_on_quit_pressed"]
